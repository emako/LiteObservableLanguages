<ui:UiWindow
    x:Class="WpfApp.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:m="clr-namespace:WpfApp.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:WpfApp.ViewModels"
    xmlns:windows="clr-namespace:WpfApp.Windows"
    Title="WpfApp.Demo"
    Width="900"
    Height="550"
    d:DataContext="{d:DesignInstance vm:ViewModel}"
    ui:WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <ui:TitleBar Title="LiteObservableLanguages Demo" />
        <ui:Card Margin="0,48,0,0" Padding="12">
            <ScrollViewer>
                <StackPanel>
                    <Menu
                        Margin="0"
                        Padding="0"
                        Background="Transparent">
                        <MenuItem Margin="0" Padding="0">
                            <MenuItem.Header>
                                <TextBlock FontSize="24">
                                    <TextBlock.Text>
                                        <I18N Key="{x:Static m:LangKeys.Current_language_is}">
                                            <LanguageBinding Key="{x:Static m:LangKeys.Language}" />
                                            <Binding Path="Culture.EnglishName" />
                                        </I18N>
                                    </TextBlock.Text>
                                </TextBlock>
                            </MenuItem.Header>
                            <ui:CodeBlock>
                                &lt;TextBlock&gt;\n
                                \t&lt;TextBlock.Text&gt;\n
                                \t\t&lt;I18N Key="{x:Static m:LangKeys.Current_language_is}"&gt;\n
                                \t\t\t&lt;LanguageBinding Key="{x:Static m:LangKeys.Language}" /&gt;\n
                                \t\t\t&lt;Binding Path="Culture.EnglishName" /&gt;\n
                                \t\t&lt;/I18N&gt;\n
                                \t&lt;TextBlock.Text&gt;\n
                                &lt;TextBlock&gt;
                            </ui:CodeBlock>
                        </MenuItem>
                    </Menu>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <ui:Card Margin="0,0,10,0" Padding="0">
                                <StackPanel>
                                    <Menu Background="Transparent">
                                        <MenuItem>
                                            <MenuItem.Header>
                                                <TextBlock Text="{I18N {x:Static m:LangKeys.Select_your_text_to_translate}}" />
                                            </MenuItem.Header>
                                            <ui:CodeBlock>
                                                &lt;TextBlock Text="{I18N {x:Static m:LangKeys.Select_your_text_to_translate}}"/&gt;
                                            </ui:CodeBlock>
                                        </MenuItem>
                                    </Menu>
                                    <ComboBox
                                        Margin="12,0"
                                        ItemsSource="{Binding AvailableKeys}"
                                        SelectedItem="{Binding SelectedKey}" />
                                    <Menu Background="Transparent">
                                        <MenuItem>
                                            <MenuItem.Header>
                                                <TextBlock Text="{I18N {x:Static m:LangKeys.Translated_text}}" />
                                            </MenuItem.Header>
                                            <ui:CodeBlock>
                                                &lt;TextBlock Text="{I18N {x:Static m:LangKeys.Translated_text}}"/&gt;
                                            </ui:CodeBlock>
                                        </MenuItem>
                                    </Menu>

                                    <TextBox Margin="12,0" Text="{I18N {Binding SelectedKey}}" />
                                    <ui:CodeBlock Margin="12">
                                        &lt;TextBlock Text="{I18N {Binding SelectedKey}}"/&gt;
                                    </ui:CodeBlock>
                                </StackPanel>
                            </ui:Card>
                            <ui:Card Grid.Row="1" Margin="0,12,10,0">
                                <StackPanel>
                                    <TextBlock Text="{I18N {x:Static m:LangKeys.Input_your_text_to_translate}}" />
                                    <TextBox Margin="0,10" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{I18N {x:Static m:LangKeys.Translated_text}}" />
                                    <TextBlock Margin="0,10" Text="{I18N {Binding InputText}}" />
                                    <ui:CodeBlock>
                                        &lt;TextBlock Text="{I18N {Binding InputText}}"/&gt;
                                    </ui:CodeBlock>
                                </StackPanel>
                            </ui:Card>
                            <ui:Card Grid.Row="2" Margin="0,12,10,0">
                                <ui:ToggleSwitch>
                                    <ui:ToggleSwitch.Style>
                                        <Style BasedOn="{StaticResource DefaultUiToggleSwitchStyle}" TargetType="{x:Type ui:ToggleSwitch}">
                                            <Setter Property="Content" Value="{I18NBinding {x:Static m:LangKeys.Off}}" />
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Content" Value="{I18NBinding {x:Static m:LangKeys.On}}" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter Property="Content" Value="{I18NBinding {x:Static m:LangKeys.Off}}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:ToggleSwitch.Style>
                                </ui:ToggleSwitch>
                            </ui:Card>
                        </StackPanel>
                        <Grid Grid.Column="1">
                            <StackPanel>
                                <TextBlock Text="{I18N {x:Static m:LangKeys.Available_languages}}" />
                                <ListBox
                                    Margin="0,10"
                                    ItemsSource="{Binding AvailableCultures}"
                                    SelectedItem="{Binding Culture}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{I18N {Binding EnglishName}}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </StackPanel>

            </ScrollViewer>
        </ui:Card>
    </Grid>

</ui:UiWindow>